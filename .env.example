# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local — it holds real secrets.

# ── Database ───────────────────────────────────────────────────────────────
# Neon Postgres — neon.tech → your project → Connection string (pooled)
DATABASE_URL=postgresql://...

# ── AI ────────────────────────────────────────────────────────────────────
# Anthropic API key — console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth ──────────────────────────────────────────────────────────────────
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=generate-with-command-above

# Public base URL — different per environment
# Local dev:
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
# Production (set in Vercel env):
# BETTER_AUTH_URL=https://logistics.aegisfestival.com
# NEXT_PUBLIC_BETTER_AUTH_URL=https://logistics.aegisfestival.com

# ── Storage ───────────────────────────────────────────────────────────────
# Vercel Blob — vercel.com → project → Storage → Blob → token
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── Email ─────────────────────────────────────────────────────────────────
# Resend — resend.com → API keys (after domain verification)
RESEND_API_KEY=re_...
EMAIL_FROM=Aegis Logistics <logistics@aegisfestival.com>

# ── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=GreenRoom Stages
NEXT_PUBLIC_APP_TZ=Asia/Beirut
